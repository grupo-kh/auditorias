# Clave secreta para las sesiones Flask (generar con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=cambia-esta-clave

# Ruta a la base de datos SQLite, relativa a la raíz del repo (ej.: data/audit.db)
DB_PATH=data/audit.db

# Interfaz de escucha de la app (ej.: 0.0.0.0 para escuchar en todas)
APP_HOST=0.0.0.0

# Puerto de escucha de la app (ej.: 8000)
APP_PORT=8000

# IP del servidor para mostrar la URL móvil; dejar vacío para autodetectar (ej.: 192.0.2.10)
SERVER_IP=

# Prefijo de URL si la app se sirve bajo una subruta detrás de un proxy inverso (ej.: /auditorias); vacío = raíz
APP_URL_PREFIX=

# URL pública base para componer la URL móvil detrás del proxy (ej.: http://mi-servidor); vacío = usar SERVER_IP:APP_PORT
PUBLIC_URL=

# Credenciales de administrador, formato usuario:contraseña separados por comas (ej.: admin:cambiar,otro:cambiar2)
ADMIN_USERS=usuario:contraseña
